# URL de prueba del flujo n8n. En producción usa el webhook de producción, no /webhook-test/.
N8N_ROUTE_WEBHOOK_URL=https://edwinhernandez.app.n8n.cloud/webhook-test/crowd-detection

# Token secreto para el fallback del backend. No uses el token público del navegador si puedes evitarlo.
MAPBOX_ACCESS_TOKEN=pega_aqui_tu_token_mapbox
PORT=3001

# SerpAPI: Popular Times (radar de intensidad de gente). Free tier 100 búsquedas/mes.
SERPAPI_KEY=pega_aqui_tu_key_serpapi
# Minutos que dura la caché de /api/crowds antes de volver a consultar SerpAPI (default 30)
CROWDS_CACHE_MINUTES=30

# Observaciones reales de aves y pronóstico climático para TwinMap.
EBIRD_API_KEY=pega_aqui_tu_key_ebird
OPENWEATHER_API_KEY=pega_aqui_tu_key_openweather

# Explicación/razonamiento IA (pronóstico de aves migratorias) vía OpenRouter.
OPENROUTER_API_KEY=pega_aqui_tu_key_openrouter
# Modelo del LLM (default: anthropic/claude-sonnet-5). Gratis: meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=anthropic/claude-sonnet-5
# Tráfico/rutas con TomTom (opcional).
TOMTOM_API_KEY=pega_aqui_tu_key_tomtom
